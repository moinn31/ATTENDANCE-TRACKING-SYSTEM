# PostgreSQL Configuration
# Use .env.local for real credentials in local development.

# Database password used by lib/db.js
POSTGRES_PASSWORD=your-postgres-password

# JWT signing secret used by app/api/auth/login/route.js
JWT_SECRET=your_secret_key_123

# Optional: Hadoop / HDFS Integration (for big data storage)
# HADOOP_HOST=localhost
# HADOOP_PORT=9000
# HDFS_WAREHOUSE_PATH=/attendance/warehouse

# Optional: Apache Spark Analytics (for big data processing)
# SPARK_MASTER=local[*]
# SPARK_DRIVER_MEMORY=2g
# SPARK_EXECUTOR_MEMORY=2g

# Optional: YOLO + ArcFace face recognition service
# FACE_RECOGNITION_SERVICE_URL=http://127.0.0.1:8000
# YOLO_FACE_MODEL=models/yolov8m-face.pt
# ARCFACE_MODEL=buffalo_l
# FACE_SIMILARITY_THRESHOLD=0.40
# YOLO_CONF_THRESHOLD=0.35
# YOLO_IMG_SIZE=960
# USE_CUDA=false
